<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <table name="mm_webforms_form" resource="default" engine="innodb">
        <!-- Klaviyo Settings -->
        <column xsi:type="boolean" name="is_klaviyo_enabled" nullable="false" default="0" comment="Klaviyo integration enabled"/>
        <column xsi:type="int" name="klaviyo_endpoint" unsigned="true" nullable="true" comment="Klaviyo Endpoint"/>
        <column xsi:type="text" name="klaviyo_event" nullable="true" comment="Klaviyo Event"/>
        <column xsi:type="int" name="klaviyo_email_field_id" unsigned="true" nullable="true" comment="Klaviyo Email Override"/>
        <column xsi:type="text" name="klaviyo_lists_serialized" nullable="true" comment="Klaviyo Lists in JSON"/>
        <column xsi:type="text" name="klaviyo_map_fields_serialized" nullable="true" comment="Klaviyo Map Fields in JSON"/>
    </table>

</schema>
